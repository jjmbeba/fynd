# Database
DATABASE_URL=sqlite+aiosqlite:///./fynd.db

# Base display currency (KES = Kenyan Shillings)
FX_BASE_CURRENCY=KES

# FX rate provider
FX_PROVIDER_URL=https://api.frankfurter.app

# Anchor hour for daily scrape (local 24h time)
SCRAPE_HOUR_LOCAL=6

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development, production
ENVIRONMENT=development

# Comma-separated CORS origins (JSON array string)
CORS_ORIGINS=["http://localhost:5173"]

# Sentry DSN (empty = no Sentry)
SENTRY_DSN=
